{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Wiki Events/sec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "sum(rate(kafka_topic_partition_current_offset{topic=\"raw-wiki-events\"}[1m]))", "legendFormat": "wiki events/sec"}]
    },
    {
      "title": "EONET Events/sec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "sum(rate(kafka_topic_partition_current_offset{topic=\"raw-natural-events\"}[1m]))", "legendFormat": "eonet events/sec"}]
    },
    {
      "title": "SL News Events/sec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "sum(rate(kafka_topic_partition_current_offset{topic=\"raw-sl-news\"}[1m]))", "legendFormat": "sl news events/sec"}]
    },
    {
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "sum by (consumergroup) (kafka_consumergroup_lag)", "legendFormat": "{{consumergroup}}"}]
    },
    {
      "title": "Topic Offsets",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{"expr": "sum by (topic) (kafka_topic_partition_current_offset{topic=~\"raw-.*\"})", "legendFormat": "{{topic}}"}]
    },
    {
      "title": "Flink Running Jobs",
      "type": "stat",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "targets": [{"expr": "flink_jobmanager_numRunningJobs", "legendFormat": "running jobs"}]
    },
    {
      "title": "Flink Checkpoint Duration",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "targets": [{"expr": "flink_jobmanager_job_lastCheckpointDuration", "legendFormat": "{{job_name}}"}]
    },
    {
      "title": "Flink Task Slots",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {"expr": "flink_jobmanager_taskSlotsTotal", "legendFormat": "total slots"},
        {"expr": "flink_jobmanager_taskSlotsAvailable", "legendFormat": "available slots"}
      ]
    },
    {
      "title": "Flink Records In/sec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [{"expr": "sum by (job_name) (rate(flink_taskmanager_job_task_operator_numRecordsIn[1m]))", "legendFormat": "{{job_name}}"}]
    },
    {
      "title": "Flink JVM Heap (TaskManager)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24},
      "targets": [{"expr": "flink_taskmanager_Status_JVM_Memory_Heap_Used", "legendFormat": "{{tm_id}}"}]
    },
    {
      "title": "Flink GC Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 24},
      "targets": [{"expr": "rate(flink_taskmanager_Status_JVM_GarbageCollector_G1_Young_Generation_Time[5m])", "legendFormat": "young GC"}]
    },
    {
      "title": "Flink Threads",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 24},
      "targets": [{"expr": "flink_taskmanager_Status_JVM_Threads_Count", "legendFormat": "{{tm_id}}"}]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["vega"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "title": "Vega Overview",
  "uid": "vega-overview",
  "version": 2
}
